# Copy to .env and fill in the secrets (the *_API_KEY values).
# Non-secret defaults are pre-filled below.

# Hyperbrowser cloud browser (the single shared browser all three models drive)
HYPERBROWSER_API_KEY=hb-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Closed frontier
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5.5          # confirm the exact GPT-5.5 model string for your account

# Open model: GLM-5.2 via one OpenAI-compatible client.
# This is the Z.ai API key — GLM_API_KEY IS your z.ai key when using the hosted API.
#
#   Z.ai hosted (default):  GLM_BASE_URL=https://api.z.ai/api/paas/v4
#   self-hosted vLLM/SGLang: GLM_BASE_URL=http://localhost:8000/v1  (GLM_API_KEY can be any non-empty value)
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-5.2             # confirm the exact GLM-5.2 model string for your access path
GLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx   # your z.ai API key

# Runs per task per model (default 3). One run is noise.
HARNESS_RUNS=3
